{
  "name": "react-splitting",
  "description": "A re-implementation of splitting.js for React supporting SSR/SSG.",
  "version": "1.0.0-rc9",
  "author": "Steven Vachon <contact@svachon.com> (https://svachon.com)",
  "repository": "github:stevenvachon/react-splitting",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/Splitting.js",
    "./splitChildren": "./src/splitChildren.js",
    "./with-meta": "./src/SplittingWithMeta.js"
  },
  "dependencies": {
    "type-fest": "^5.3.1"
  },
  "peerDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/splitting": "^1.0.6",
    "@vitest/coverage-v8": "^4.0.15",
    "cssnano": "^7.1.2",
    "htmlnano": "^2.1.5",
    "jsdom": "^27.3.0",
    "prettier": "^3.7.4",
    "splitting": "^1.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "scripts": {
    "build": "prettier --check 'src/*.tsx' && tsc",
    "prepublishOnly": "npm run build && npm test",
    "test": "npm run test:watch -- --reporter=verbose --run",
    "test:watch": "vitest dev --coverage --coverage.exclude=src/testHelpers.tsx --coverage.reporter=lcov --coverage.reporter=text --environment=jsdom --globals"
  },
  "files": [
    "src/constants.d.ts",
    "src/constants.js",
    "src/constants.js.map",
    "src/splitChildren.d.ts",
    "src/splitChildren.js",
    "src/splitChildren.js.map",
    "src/Splitting.d.ts",
    "src/Splitting.js",
    "src/Splitting.js.map",
    "src/SplittingWithMeta.d.ts",
    "src/SplittingWithMeta.js",
    "src/SplittingWithMeta.js.map",
    "src/types.d.ts"
  ],
  "keywords": [
    "animation",
    "char",
    "split",
    "splitting",
    "text",
    "word"
  ]
}
