{
  "name": "react-splitting",
  "description": "A re-implementation of splitting (a text segmenter for animation) for React supporting SSR/SSG.",
  "version": "1.0.0-rc20",
  "author": "Steven Vachon <contact@svachon.com> (https://svachon.com)",
  "repository": "github:stevenvachon/react-splitting",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./dist/splitting/index.js",
    "./types": "./dist/types.d.ts",
    "./with-meta": "./dist/splittingWithMeta/index.js"
  },
  "dependencies": {
    "type-fest": "^5.4.4"
  },
  "peerDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/splitting": "^1.0.6",
    "@vitest/coverage-v8": "^4.0.18",
    "copyfiles": "^2.4.1",
    "cspell": "^10.0.0",
    "cssnano": "^7.1.2",
    "happy-dom": "^20.6.2",
    "htmlnano": "^3.1.0",
    "prettier": "^3.8.1",
    "splitting": "^1.1.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.2",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "build": "npm run build:spellcheck && npm run build:lint && npm run build:typecheck:supplemental && npm run build:compile",
    "build:compile": "tsc --project tsconfig.build.json && copyfiles -u 1 'src/**/*.d.ts' dist/ && tsc-alias --outDir=dist --resolve-full-paths --resolve-full-extension .js",
    "build:lint": "prettier --check '*.{config.js,json,md}' 'src/**/*.{ts,tsx}'",
    "build:spellcheck": "cspell '*.{config.js,json,md}' 'src/**/*.{ts,tsx}' --cache --no-progress",
    "build:typecheck:supplemental": "tsc --project tsconfig.check.json",
    "prepublishOnly": "npm run build && npm test",
    "test": "npm run test:watch -- --reporter=verbose --run",
    "test:watch": "vitest dev --coverage --coverage.exclude=src/testHelpers.tsx --coverage.reporter=html --coverage.reporter=lcov --coverage.reporter=text --environment=happy-dom --globals"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "animation",
    "char",
    "react",
    "split",
    "splitting",
    "text",
    "word"
  ]
}
