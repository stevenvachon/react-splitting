{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "declaration": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": ["dom", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2024"
  },
  "exclude": ["*.test.tsx"],
  "include": ["*.tsx"]
}
